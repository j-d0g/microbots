# microbots — /web env template. Copy to .env.local.
# All keys are OPTIONAL for local dev: the app boots against scripted
# fallback events if none are set. Fill in when you're wiring up the
# real agent.

# --- Agent (orchestrator + layout-agent + content-agent) ---
# OpenRouter key. Powers the new /api/agent/orchestrate route through
# the Vercel AI SDK with `google/gemini-2.5-flash-lite`. Without it,
# the command bar falls back to local keyword scripts
# (lib/agent-router.ts).
OPENROUTER_API_KEY=

# Optional override of the model slug. Any OpenRouter model that
# supports tool calls works. Defaults to google/gemini-2.5-flash-lite
# — kept locked there for cost control; do not change without an
# eval-justified reason (see web/agent-evals/AGENTS.md).
OPENROUTER_MODEL=

# --- Backend (Pydantic AI + SurrealDB, future) ---
# Base URL of the Python agent server. Reserved for the future
# Pydantic AI sidecar. The current orchestrator runs entirely in
# Next.js and does NOT use this.
AGENT_BASE_URL=

# --- Deepgram STT ---
# Server-side key. The browser requests a short-lived token via
# /api/deepgram/token — never expose this directly.
DEEPGRAM_API_KEY=

# --- Cartesia TTS (fallback ElevenLabs) ---
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Feature flags ---
# When true, UI surfaces agent tool-call events from a timer-driven mock stream.
# Useful for designing rooms without the backend running.
NEXT_PUBLIC_MOCK_AGENT=true
