# microbots — /web env template. Copy to .env.local.
# All keys are OPTIONAL for local dev: the app boots against scripted
# fallback events if none are set. Fill in when you're wiring up the
# real agent.

# --- Agent (orchestrator + layout-agent + content-agent) ---
# OpenRouter key. Powers the new /api/agent/orchestrate route through
# the Vercel AI SDK with `google/gemini-2.5-flash-lite`. Without it,
# the command bar falls back to local keyword scripts
# (lib/agent-router.ts).
OPENROUTER_API_KEY=

# Optional override of the model slug. Any OpenRouter model that
# supports tool calls works. Defaults to google/gemini-2.5-flash-lite
# — kept locked there for cost control; do not change without an
# eval-justified reason (see web/agent-evals/AGENTS.md).
OPENROUTER_MODEL=

# --- Backend (Pydantic AI + SurrealDB, future) ---
# Base URL of the Python agent server. Reserved for the future
# Pydantic AI sidecar. The current orchestrator runs entirely in
# Next.js and does NOT use this.
AGENT_BASE_URL=

# --- Deepgram STT ---
# Server-side key. The browser requests a short-lived token via
# /api/deepgram/token — never expose this directly.
DEEPGRAM_API_KEY=

# --- Cartesia TTS (fallback ElevenLabs) ---
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- ElevenLabs Conversational AI (real-time voice) ---
# Get your Agent ID from the ElevenLabs dashboard (ConvAI section)
# This is used client-side for the WebSocket connection
NEXT_PUBLIC_ELEVENLABS_CONVAI_AGENT_ID=
# Optional: client-side API key (if not using token endpoint)
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# --- Microbots backend (live) ---
# Public base URL of the unified microbots service. Hosts both the
# Composio OAuth proxy (/api/composio/*) and the SurrealDB-backed
# knowledge graph (/api/kg/*). Defaults to the deployed Render
# instance; override for a local Python dev server.
NEXT_PUBLIC_MICROBOTS_BASE_URL=https://app-bf31.onrender.com

# Optional override for the KG REST surface specifically. Falls back
# to NEXT_PUBLIC_MICROBOTS_BASE_URL when unset (same origin). Set this
# only if the KG backend is hosted separately from Composio OAuth.
# See `web/lib/kg-client.ts` and `docs/api-kg-contract.md`.
NEXT_PUBLIC_KG_API_BASE=

# --- Harness MCP (run_code / save_workflow / search_memory) ---
# Optional. Points the orchestrator's run_code tool at the deployed
# Python FastMCP harness (`agent/harness/mcp/server.py`). When unset,
# run_code returns a graceful "harness MCP not configured" envelope
# and the rest of the agent (KG reads/writes) still works.
HARNESS_MCP_URL=
HARNESS_MCP_TOKEN=

# --- Feature flags ---
# When true, UI surfaces agent tool-call events from a timer-driven mock stream.
# Useful for designing rooms without the backend running.
NEXT_PUBLIC_MOCK_AGENT=true
