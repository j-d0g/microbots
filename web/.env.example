# microbots — /web env template. Copy to .env.local.
# All keys are OPTIONAL for local dev: the app boots against mocked agent
# events if none are set. Fill in when you're wiring up real voice + agent.

# --- Backend (Pydantic AI + SurrealDB) ---
# Base URL of the Python agent server. When set, /api/agent/stream proxies
# SSE here. Otherwise it emits mocked ROOM/VERB/CARD events for UI dev.
AGENT_BASE_URL=

# --- Deepgram STT ---
# Server-side key. The browser requests a short-lived token via
# /api/deepgram/token — never expose this directly.
DEEPGRAM_API_KEY=

# --- Cartesia TTS (fallback ElevenLabs) ---
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Feature flags ---
# When true, UI surfaces agent tool-call events from a timer-driven mock stream.
# Useful for designing rooms without the backend running.
NEXT_PUBLIC_MOCK_AGENT=true
