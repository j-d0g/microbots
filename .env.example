# =============================================================================
# microbots — environment configuration
# Copy to `.env` (or `.env.local`) and fill in the secrets. Git-ignored.
# Makefile (`include .env`) and Python `load_dotenv()` read .env from the project root.
# =============================================================================

# --- SurrealDB (docker-compose, schema, seed, ingest) ---
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=microbots
SURREAL_DB=memory
SURREAL_PORT=8000
SURREAL_URL=ws://localhost:8000/rpc

# --- Composio (make composio-ingest / python -m ingest) ---
# API key is not enough: run `composio login` and `composio link` each toolkit
# (e.g. slack, github, gmail, linear, notion, perplexityai) first
# (see https://docs.composio.dev/docs/cli — not `composio add`). Or use the dashboard.
COMPOSIO_API_KEY=
# Must match the Composio "user" that owns the connected accounts (default = CLI default).
COMPOSIO_USER_ID=default
# Optional but recommended when your links use consumer-style user ids:
# COMPOSIO_ORG_ID=ok_xxx

# --- LLM triage (at least one key needed for a full ingest) ---
# OpenRouter (default provider in config.py, model e.g. nvidia/nemotron-…)
OPENROUTER_API_KEY=
# Optional: use Anthropic instead by setting config.llm.provider in config.py
ANTHROPIC_API_KEY=

# OpenRouter request attribution (optional; some setups require a referer)
# OPENROUTER_HTTP_REFERER=https://github.com/your-org/microbots
# OPENROUTER_X_TITLE=microbots

# Optional: real LLM during `python -m ingest --smoke` (else static JSON for triage)
# INGEST_SMOKE_USE_LLM=true

# Optional: Composio client cache directory (ingest also defaults to ./.composio_cache)
# COMPOSIO_CACHE_DIR=

# --- Logfire (Pydantic Observability) ---
# Leaving LOGFIRE_TOKEN empty keeps output local-only (console); set it to ship
# the same records to Logfire as well.
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=microbots
LOGFIRE_ENVIRONMENT=dev

# Region is auto-detected from the token prefix:
#   pylf_v1_eu_*   -> https://logfire-eu.pydantic.dev
#   pylf_v1_us_*   -> https://logfire-us.pydantic.dev
# Only set LOGFIRE_BASE_URL to override that auto-routing.
# LOGFIRE_BASE_URL=https://logfire-eu.pydantic.dev

# Leave blank to generate a fresh 12-char correlation id on every process start.
# Set explicitly (e.g. from a parent orchestrator) to correlate work across
# multiple processes or jobs.
# CORRELATION_ID=

# --- render_sdk (test/deploy_fastapi_demo.py, render_sdk.RenderSDK) ---
# Generate at https://dashboard.render.com/settings#api-keys
RENDER_API_KEY=
# Docker Hub account used by the SDK to build & push the deployable image.
# DOCKER_ORG is the namespace in the image tag (usually == DOCKER_USER for solo accounts).
DOCKER_USER=
DOCKER_ORG=
# Generate at https://app.docker.com/settings/personal-access-tokens (Read, Write)
DOCKER_TOKEN=

# --- Devin (planner / monitor agents drive Devin via /mcp/devin + /api/devin) ---
# Service or personal API key from https://app.devin.ai/settings — starts with `apk_` (or `apk_user_`).
DEVIN_API_KEY=
# Default base URL for the v1 API. Override only if you've been pointed at a private endpoint.
# DEVIN_API_BASE=https://api.devin.ai/v1
